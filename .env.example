# Promptuno uses Pollinations' public text API by default, so no AI key is required.
# Optional: add a Pollinations key if you want higher limits or authenticated models.
POLLINATIONS_API_KEY=

# Optional: override the default free text model.
POLLINATIONS_MODEL=openai

# Optional: override the provider URL.
# Leave empty to use the no-key public endpoint, or set a custom OpenAI-compatible URL.
POLLINATIONS_API_URL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
