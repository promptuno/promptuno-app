# Optional, server-only: use OpenAI from the Express /api/generate route.
# Never expose this in browser code or commit a real key to GitHub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CORS_ORIGIN=https://promptuno.github.io

# Promptuno uses Pollinations' public text API when OpenAI is not configured.
# Optional: add a Pollinations key if you want higher limits or authenticated models.
POLLINATIONS_API_KEY=

# Optional: override the default free text model.
POLLINATIONS_MODEL=openai

# Optional: override the provider URL.
# Leave empty to use the no-key public endpoint, or set a custom OpenAI-compatible URL.
POLLINATIONS_API_URL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional, public frontend setting: point a static frontend to your private backend.
# Example: VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=

# Optional, public frontend PayPal settings.
# VITE_PAYPAL_CLIENT_ID enables embedded PayPal checkout buttons.
# VITE_PAYPAL_PLAN_ID enables PayPal Subscriptions for the $15/mo plan.
# Without these, the app falls back to PayPal Standard checkout to AFI5@OUTLOOK.COM.
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_PLAN_ID=
