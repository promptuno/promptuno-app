{
  "manifest_version": 3,
  "name": "Promptuno - Prompt and Write",
  "short_name": "Promptuno",
  "version": "0.1.0",
  "description": "Generate better prompts and polished writing anywhere you work.",
  "action": {
    "default_title": "Promptuno",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": ["https://text.pollinations.ai/*"],
  "commands": {
    "promptuno-improve-selection": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "Open Promptuno for selected text"
    }
  }
}
